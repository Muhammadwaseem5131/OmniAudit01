# =============================================================================
# OmniAudit — .gitignore
# =============================================================================

# ---- Secrets (NEVER commit) ----
.env
*.env
.env.local
.env.production

# ---- Python Cache ----
__pycache__/
*.py[cod]
*$py.class
*.pyo
.pytest_cache/
.mypy_cache/
*.egg-info/
.eggs/

# ---- Virtual Environments ----
.venv/
venv/
env/
ENV/

# ---- Node / Frontend ----
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
dist/
build/
.next/

# ---- Generated Outputs (rebuilt each run) ----
output/
*.log

# ---- OS Files ----
.DS_Store
Thumbs.db
Desktop.ini

# ---- IDE / Editor ----
.vscode/
.idea/
*.swp
*.swo

# ---- Temp / Build Artifacts ----
*.egg-info/
*.whl
*.zip
*.tar.gz
temp_slides.html
generate_media.py
