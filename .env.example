# OmniAudit Environment Variables
# =================================
# 1. Copy this file:  cp .env.example .env   (Windows: copy .env.example .env)
# 2. Fill in your real API keys below
# 3. NEVER commit .env to GitHub — it is already in .gitignore
#
# Get API keys from:
#   Gemini:     https://aistudio.google.com
#   VirusTotal: https://www.virustotal.com/gui/my-apikey
#   AbuseIPDB:  https://www.abuseipdb.com/api
#   NVD/CVE:    https://nvd.nist.gov/developers/request-an-api-key
# =================================

# ---- Core AI (Required) ----
GOOGLE_API_KEY=your_gemini_api_key_here

# ---- Security Intelligence APIs (Optional — agents degrade gracefully) ----
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here
ABUSEIPDB_API_KEY=your_abuseipdb_api_key_here
NVD_API_KEY=your_nvd_api_key_here

# ---- Wazuh SIEM Integration (Optional) ----
WAZUH_API_URL=http://your_wazuh_host:55000
WAZUH_API_USER=your_wazuh_username
WAZUH_API_PASS=your_wazuh_password

# ---- Backend / Frontend URLs ----
BACKEND_URL=http://localhost:8000
FRONTEND_PORT=3000
